{
	"$schema": "https://json.schemastore.org/prettierrc",

	"useTabs": true,
	"tabWidth": 4,

	"semi": true,
	"singleQuote": true,
	"jsxSingleQuote": false,

	"trailingComma": "all",

	"printWidth": 100,
	"arrowParens": "always",
	"bracketSpacing": true,
	"endOfLine": "lf",

	"plugins": ["@ianvs/prettier-plugin-sort-imports"],

	"overrides": [
		{
			"files": ["*.json", "*.yml", "*.yaml"],
			"options": {
				"useTabs": false,
				"tabWidth": 4
			}
		},
		{
			"files": ["*.md"],
			"options": {
				"proseWrap": "always"
			}
		},
		{
			"files": ["*.sql"],
			"options": {
				"language": "postgresql",
				"keywordCase": "upper",
				"tabWidth": 4
			}
		}
	]
}